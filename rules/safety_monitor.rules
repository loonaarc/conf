/*
This file defines the openHAB rules for the safety monitor project.
*/

// Recalculate the local safety risk score whenever relevant context changes.
// This rule summarizes distributed sensor evidence into RiskScore, RiskLevel, and AlarmState.
rule "Recalculate Safety Risk Score and Alarm State"
when
    Item Motion changed or
    Item Door changed or
    Item Vibration changed or
    Item SoundLevel changed or
    Item AustriaWarningCount changed or
    Item AustriaWarningLevel changed or
    Item AlarmAutomation changed or
    Item Relay changed or
    Item Buzzer changed
then
    var Number score = 0

    if (Door.state == ON) {
        score = score + 2
    }

    if (Motion.state == ON) {
        score = score + 1
    }

    if (Vibration.state == "ON") {
        score = score + 2
    }

    if (SoundLevel.state != NULL && SoundLevel.state != UNDEF) {
        val Number sound = SoundLevel.state as Number
        if (sound.intValue > 100) {
            score = score + 2
        }
    }


    if (AustriaWarningCount.state != NULL && AustriaWarningCount.state != UNDEF) {
        val Number warningCount = AustriaWarningCount.state as Number
        if (warningCount.intValue > 0) {
            score = score + 1
        }
    }

    if (AustriaWarningLevel.state != NULL && AustriaWarningLevel.state != UNDEF) {
        val Number warningLevel = AustriaWarningLevel.state as Number
        if (warningLevel.intValue >= 3) {
            score = score + 1
        }
    }

    RiskScore.postUpdate(score)

    if (score.intValue >= 6) {
        RiskLevel.postUpdate("CRITICAL")
    } else if (score.intValue >= 4) {
        RiskLevel.postUpdate("HIGH")
    } else if (score.intValue >= 2) {
        RiskLevel.postUpdate("MEDIUM")
    } else {
        RiskLevel.postUpdate("LOW")
    }

    if (Relay.state == ON || Buzzer.state == ON) {
        AlarmState.postUpdate("ALARM_ACTIVE")
    } else if (AlarmAutomation.state == ON) {
        AlarmState.postUpdate("ARMED")
    } else {
        AlarmState.postUpdate("IDLE")
    }
end

// Trigger the alarm when the calculated risk level becomes high enough.
rule "Risk Level Triggers Alarm"
when
    Item RiskLevel changed
then
    if (AlarmAutomation.state == ON && (RiskLevel.state == "HIGH" || RiskLevel.state == "CRITICAL")) {
        Relay.sendCommand(ON)
        Buzzer.sendCommand(ON)
    }
end


// Rule to disable the alarm when touch is detected.
rule "Touch Acknowledges Alarm"
when
    Item Touch received update "ON"
then
    Relay.sendCommand(OFF)
    Buzzer.sendCommand(OFF)
    AlarmState.postUpdate("ACKNOWLEDGED")
end

// Rule to control the buzzer power based on the selected intensity level when the buzzer is turned ON.
rule "Buzzer Power Uses Selected Intensity"
when
    Item Buzzer received command ON
then
    var Number level = 50

    if (BuzzerLevel.state != NULL && BuzzerLevel.state != UNDEF) {
        level = BuzzerLevel.state as Number
    } else {
        BuzzerLevel.postUpdate(level)
    }

    BuzzerCommand.sendCommand(level.intValue)
end

// Rule to update the buzzer intensity if the level is changed while the buzzer is ON.
rule "Buzzer Intensity Changes While On"
when
    Item BuzzerLevel changed
then
    if (Buzzer.state == ON && BuzzerLevel.state != NULL && BuzzerLevel.state != UNDEF) {
        val Number level = BuzzerLevel.state as Number
        BuzzerCommand.sendCommand(level.intValue)
    }
end

// Rule to initialize the monitored area location on system startup. This sets a default location that can be displayed in the UI and used in rules if needed.
rule "Initialize Monitored Area Location"
when
    System started
then
    MonitoredArea.postUpdate("48.2082,16.3738")
end
