/*
This file defines the openHAB rules for the safety monitor project.
*/

// Rule to trigger the alarm when both motion and door are detected, but only if motion automation is enabled.
rule "Door And Motion Trigger Alarm"
when
    Item Motion changed or
    Item Door changed
then
    if (MotionAutomation.state == ON && Door.state == ON && Motion.state == ON) {
        Relay.sendCommand(ON)
        Buzzer.sendCommand(ON)
    }
end

// Rule to trigger the alarm when both vibration and door are detected, but only if motion automation is enabled.
rule "Door And Vibration Trigger Alarm"
when
    Item Vibration received update "ON"
then
    if (MotionAutomation.state == ON && Door.state == ON) {
        Relay.sendCommand(ON)
        Buzzer.sendCommand(ON)
    }
end

// Rule to disable the alarm when touch is detected.
rule "Touch Disables Alarm"
when
    Item Touch received update "ON"
then
    Relay.sendCommand(OFF)
    Buzzer.sendCommand(OFF)
end

// Rule to control the buzzer power based on the selected intensity level when the buzzer is turned ON.
rule "Buzzer Power Uses Selected Intensity"
when
    Item Buzzer received command ON
then
    var Number level = 50

    if (BuzzerLevel.state != NULL && BuzzerLevel.state != UNDEF) {
        level = BuzzerLevel.state as Number
    } else {
        BuzzerLevel.postUpdate(level)
    }

    BuzzerCommand.sendCommand(level.intValue)
end

// Rule to update the buzzer intensity if the level is changed while the buzzer is ON.
rule "Buzzer Intensity Changes While On"
when
    Item BuzzerLevel changed
then
    if (Buzzer.state == ON && BuzzerLevel.state != NULL && BuzzerLevel.state != UNDEF) {
        val Number level = BuzzerLevel.state as Number
        BuzzerCommand.sendCommand(level.intValue)
    }
end
