@startuml
title Distributed Edge-Based Safety Monitoring - Network Plan

skinparam shadowing false
skinparam componentStyle rectangle
skinparam wrapWidth 180

cloud "Internet" as internet {
  rectangle "GeoSphere Austria\nWarn API\nHTTPS JSON" as geosphere
}

node "Laptop / openHAB Host\nIP: 192.168.43.26" as laptop {
  component "Mosquitto MQTT Broker\nlocalhost:1883" as mosquitto
  component "openHAB 5.1.4\nMQTT + HTTP bindings\nBasic UI + Rules" as openhab
  component "MQTT Explorer\nDebug / Evidence" as explorer
  component "Browser\nBasic UI + Tasmota UIs" as browser
}

node "Wi-Fi Router / Hotspot\n192.168.43.x" as wifi

node "ESP #1 Safety Monitor\nIP: 192.168.43.223\nMQTT topic: safety_monitor_1" as esp1 {
  component "PIR motion\nD2 / Switch1" as pir
  component "Reed door\nD6 / Switch2" as reed
  component "DS18B20 temperature\nD4 / DS18x20" as temp
}

node "ESP #2 Safety Alarm\nIP: 192.168.43.110\nMQTT topic: safety_alarm_1" as esp2 {
  component "Relay\nD1 / Relay1" as relay
  component "PWM buzzer\nD5 / PWM1" as buzzer
}

node "ESP #3 Safety Context\nIP: 192.168.43.240\nMQTT topic: safety_context_1" as esp3 {
  component "Vibration\nD1 / Switch1" as vibration
  component "Touch acknowledge\nD5 / Switch2" as touch
  component "Microphone analog\nA0 / ADC" as mic
}

esp1 --> wifi : Wi-Fi
esp2 --> wifi : Wi-Fi
esp3 --> wifi : Wi-Fi
laptop --> wifi : Wi-Fi

esp1 --> mosquitto : MQTT telemetry/events\ntele/stat safety_monitor_1
esp3 --> mosquitto : MQTT telemetry/events\ntele/stat safety_context_1
openhab --> mosquitto : MQTT binding\nsubscribe/publish
mosquitto --> esp2 : MQTT commands\ncmnd/safety_alarm_1
explorer --> mosquitto : MQTT inspection

browser --> openhab : Basic UI\nlocalhost:8080
browser --> esp1 : Tasmota Web UI
browser --> esp2 : Tasmota Web UI
browser --> esp3 : Tasmota Web UI

openhab --> geosphere : HTTP binding\nGeoSphere warning JSON

note right of openhab
Rule logic:
door AND (motion OR vibration)
-> relay + buzzer ON

touch ON
-> relay + buzzer OFF
end note

@enduml
